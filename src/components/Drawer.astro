---
import { LINKS } from "@consts"
import { cn } from "@lib/utils"
const { pathname } = Astro.url
const subpath = pathname.match(/[^/]+/g)
---

<div id="drawer" class="fixed inset-0 h-0 z-40 overflow-hidden flex flex-col items-center justify-center md:hidden transition-[height] duration-300 ease-in-out" style="background-color: #0d0d0d;">
  <nav class="flex flex-col items-center space-y-4">
    {
      LINKS.map((LINK) => (
        <a
          href={LINK.HREF}
          class={cn(
            "flex items-center justify-center px-3 py-1 text-sm transition-colors duration-300 ease-in-out",
            pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF
              ? "text-[#d4a8bc] border-b border-[#d4a8bc]"
              : "text-white/60 hover:text-[#d4a8bc]"
          )}
        >
          {LINK.TEXT}
        </a>
      ))
    }
  </nav>
</div>

<style>
  #drawer.open {
    @apply h-full;
  }
</style>
