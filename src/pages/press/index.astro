---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { PRESS } from "@consts"

const press = (await getCollection("press"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { month: "long", year: "numeric" })
}

const typeLabel: Record<string, string> = {
  print: "Print",
  podcast: "Podcast",
  radio: "Radio",
  online: "Online",
}
---

<PageLayout title={PRESS.TITLE} description={PRESS.DESCRIPTION}>
  <TopLayout>
    <div class="animate">
      <p class="text-[10px] uppercase tracking-widest text-white/30">{PRESS.TITLE}</p>
    </div>
  </TopLayout>
  <BottomLayout>
    <ul class="animate border-t border-white/[0.07]">
      {press.map((entry, i) => (
        <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_2rem] gap-4 items-start">
          <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="min-w-0">
            {entry.data.url ? (
              <a
                href={entry.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-white hover:text-[#d4a8bc] transition-colors duration-200 line-clamp-2"
              >
                {entry.data.title}
              </a>
            ) : (
              <div class="text-sm text-white line-clamp-2">{entry.data.title}</div>
            )}
            <div class="flex flex-wrap items-center gap-3 mt-0.5">
              <span class="text-xs text-white/40">
                {entry.data.outlet} &middot; {formatDate(entry.data.date)}
              </span>
              <span class="text-[9px] text-white/25 border border-white/[0.1] px-1.5 py-0.5 uppercase tracking-wide">
                {typeLabel[entry.data.type] ?? entry.data.type}
              </span>
            </div>
          </div>
          <span class="text-xs text-[#d4a8bc]/50 text-right mt-0.5">
            {entry.data.url ? "↗" : ""}
          </span>
        </li>
      ))}
    </ul>
  </BottomLayout>
</PageLayout>
