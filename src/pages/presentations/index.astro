---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { PRESENTATIONS } from "@consts"

const presentations = (await getCollection("presentations"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<PageLayout title={PRESENTATIONS.TITLE} description={PRESENTATIONS.DESCRIPTION}>
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        {PRESENTATIONS.TITLE}
      </h1>
      <div class="mt-1">
        {PRESENTATIONS.DESCRIPTION}
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <ul class="animate divide-y divide-black/10 dark:divide-white/10">
      {presentations.map((entry) => (
        <li class="py-4">
          <div class="font-medium text-black dark:text-white">
            {entry.data.title}
          </div>
          <div class="text-sm opacity-60 mt-0.5">
            {entry.data.event} &middot; {entry.data.date.getFullYear()}
          </div>
          {entry.data.presenters && entry.data.presenters.length > 0 && (
            <div class="text-sm opacity-50 italic mt-0.5">
              {entry.data.presenters.join(", ")}
            </div>
          )}
          {entry.data.description && (
            <div class="text-sm opacity-75 mt-1">
              {entry.data.description}
            </div>
          )}
          {(entry.data.video_url || entry.data.slides_url) && (
            <div class="flex flex-wrap gap-3 mt-2">
              {entry.data.video_url && (
                <a
                  href={entry.data.video_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm underline decoration-[.5px] underline-offset-2 hover:opacity-100 opacity-75 blend"
                >
                  Watch recording →
                </a>
              )}
              {entry.data.slides_url && (
                <a
                  href={entry.data.slides_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm underline decoration-[.5px] underline-offset-2 hover:opacity-100 opacity-75 blend"
                >
                  View slides →
                </a>
              )}
            </div>
          )}
        </li>
      ))}
    </ul>
  </BottomLayout>
</PageLayout>
