---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { PRESENTATIONS } from "@consts"

const presentations = (await getCollection("presentations"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<PageLayout title={PRESENTATIONS.TITLE} description={PRESENTATIONS.DESCRIPTION}>
  <TopLayout>
    <div class="animate">
      <p class="text-[10px] uppercase tracking-widest text-white/30">{PRESENTATIONS.TITLE}</p>
    </div>
  </TopLayout>
  <BottomLayout>
    <ul class="animate border-t border-white/[0.07]">
      {presentations.map((entry, i) => (
        <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
          <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="min-w-0">
            <div class="text-sm text-white line-clamp-2">
              {entry.data.title}
            </div>
            <div class="text-xs text-white/40 mt-0.5">
              {entry.data.event}
              {entry.data.presenters && entry.data.presenters.length > 0 && (
                <span class="text-white/25"> &middot; {entry.data.presenters.join(", ")}</span>
              )}
            </div>
            {entry.data.description && (
              <div class="text-xs text-white/35 mt-1">
                {entry.data.description}
              </div>
            )}
            {(entry.data.video_url || entry.data.slides_url) && (
              <div class="flex flex-wrap gap-2 mt-2">
                {entry.data.video_url && (
                  <a
                    href={entry.data.video_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[10px] text-[#d4a8bc] border border-[#d4a8bc]/30 px-2 py-0.5 uppercase tracking-wide hover:bg-[#d4a8bc]/10 transition-colors duration-200"
                  >
                    Video
                  </a>
                )}
                {entry.data.slides_url && (
                  <a
                    href={entry.data.slides_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[10px] text-[#d4a8bc] border border-[#d4a8bc]/30 px-2 py-0.5 uppercase tracking-wide hover:bg-[#d4a8bc]/10 transition-colors duration-200"
                  >
                    Slides
                  </a>
                )}
              </div>
            )}
          </div>
          <span class="text-xs text-white/35 text-right tabular-nums mt-0.5">{entry.data.date.getFullYear()}</span>
        </li>
      ))}
    </ul>
  </BottomLayout>
</PageLayout>
