---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { GRANTS } from "@consts"

const grants = (await getCollection("grants"))
  .sort((a, b) => b.data.year - a.data.year)
---

<PageLayout title={GRANTS.TITLE} description={GRANTS.DESCRIPTION}>
  <TopLayout>
    <div class="animate">
      <p class="text-[10px] uppercase tracking-widest text-white/30">{GRANTS.TITLE}</p>
    </div>
  </TopLayout>
  <BottomLayout>
    <ul class="animate border-t border-white/[0.07]">
      {grants.map((entry, i) => (
        <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
          <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="min-w-0">
            {entry.data.url ? (
              <a
                href={entry.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-white hover:text-[#d4a8bc] transition-colors duration-200 line-clamp-2"
              >
                {entry.data.title}
              </a>
            ) : (
              <div class="text-sm text-white line-clamp-2">
                {entry.data.title}
              </div>
            )}
            <div class="text-xs text-white/40 mt-0.5">
              {entry.data.funder}
              {entry.data.amount && (
                <span class="text-white/25"> &middot; {entry.data.amount}</span>
              )}
            </div>
            {entry.data.description && (
              <div class="text-xs text-white/35 mt-1">
                {entry.data.description}
              </div>
            )}
          </div>
          <span class="text-xs text-white/35 text-right tabular-nums mt-0.5">{entry.data.year}</span>
        </li>
      ))}
    </ul>
  </BottomLayout>
</PageLayout>
