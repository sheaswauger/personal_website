---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { GRANTS } from "@consts"

const grants = (await getCollection("grants"))
  .sort((a, b) => b.data.year - a.data.year)
---

<PageLayout title={GRANTS.TITLE} description={GRANTS.DESCRIPTION}>
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        {GRANTS.TITLE}
      </h1>
      <div class="mt-1">
        {GRANTS.DESCRIPTION}
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <ul class="animate divide-y divide-black/10 dark:divide-white/10">
      {grants.map((entry) => (
        <li class="py-4">
          <div class="font-medium text-black dark:text-white">
            {entry.data.title}
          </div>
          <div class="text-sm opacity-60 mt-0.5">
            {entry.data.funder} &middot; {entry.data.year}
          </div>
          {entry.data.amount && (
            <div class="text-sm opacity-75 mt-0.5">
              {entry.data.amount}
            </div>
          )}
          {entry.data.description && (
            <div class="text-sm opacity-60 mt-1">
              {entry.data.description}
            </div>
          )}
        </li>
      ))}
    </ul>
  </BottomLayout>
</PageLayout>
