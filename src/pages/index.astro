---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import { SITE } from "@consts"

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)

const writing = (await getCollection("writing"))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3)
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <!-- HERO -->
  <section class="relative w-full">
    <div class="animate w-full">
      <div class="relative w-full">
        <div class="p-5 pt-32 pb-16 text-center">
          <p class="animated text-5xl md:text-6xl font-bold text-black dark:text-white">
            Shea Swauger
          </p>
          <p class="animated text-xl text-black/60 dark:text-white/60 mt-3 max-w-lg mx-auto">
            Hi there! It's nice to meet you. I'm a researcher and writer who cares about technology, public policy, and education.
          </p>
          <div id="ctaButtons" class="animated flex flex-wrap gap-4 justify-center mt-5">
            <button id="veryImportantBtn" class="bg-transparent border border-white/40 text-white px-5 py-2 rounded-full text-sm hover:bg-white/10 transition-colors cursor-pointer">
              Important Reminder
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>


  <hr class="my-8 border-black/10 dark:border-white/10">

  <!-- Divider -->
  <div class="relative bg-white dark:bg-black">
    <div class="border-t border-black/10 dark:border-white/25"></div>

    <!-- Two-column section -->
    <div class="mx-auto max-w-screen-lg px-5 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Left: Recent Blog Posts -->
        <section class="animate">
          <div class="space-y-4">
            <div class="flex justify-between items-baseline">
              <p class="font-semibold text-black dark:text-white">
                Recent Posts
              </p>
              <a href="/blog" class="group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend text-sm">
                <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                  All posts
                </span>
              </a>
            </div>
            <ul class="space-y-4">
              {posts.map((post) => (
                <li>
                  <ArrowCard entry={post} />
                </li>
              ))}
            </ul>
          </div>
        </section>

        <!-- Right: Recent Writing -->
        <section class="animate">
          <div class="space-y-4">
            <div class="flex justify-between items-baseline">
              <p class="font-semibold text-black dark:text-white">
                Recent Writing
              </p>
              <a href="/writing" class="group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend text-sm">
                <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                  All writing
                </span>
              </a>
            </div>
            <ul class="space-y-5">
              {writing.map((entry) => (
                <li>
                  <a
                    href={entry.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out"
                  >
                    <div class="font-medium text-black dark:text-white group-hover:underline decoration-[.5px] underline-offset-2 line-clamp-2">
                      {entry.data.title}
                    </div>
                    <div class="text-sm opacity-60 mt-0.5">
                      {entry.data.venue} · {entry.data.year}
                    </div>
                  </a>
                </li>
              ))}
            </ul>

            <!-- Snake game -->
            <div class="mt-8">
              <div class="flex justify-between items-baseline mb-2">
                <span id="snake-best" class="text-xs text-black/30 dark:text-white/30">best: 0</span>
                <div class="flex items-center gap-2">
                  <span id="snake-speed-dots" class="flex gap-0.5"></span>
                  <span id="snake-score" class="text-xs text-black/30 dark:text-white/30">score: 0</span>
                </div>
              </div>
              <div class="border border-white/15 rounded-lg p-3 inline-block">
                <canvas id="snake-canvas" width="420" height="300" class="block"></canvas>
              </div>
              <p class="text-xs text-white/20 text-center mt-2">arrow keys to play</p>
            </div>
          </div>
        </section>

      </div>
    </div>
  </div>


<!-- Fullscreen encouragement overlay -->
<div id="encouragementOverlay" style="display:none; opacity:0;" class="fixed inset-0 z-[9999] bg-black flex items-center justify-center transition-opacity duration-300">
  <button id="overlayClose" class="absolute top-6 right-8 text-white text-2xl cursor-pointer bg-transparent border-none leading-none">&times;</button>
  <div class="flex flex-col items-center">
    <p class="text-white text-5xl md:text-6xl font-bold text-center max-w-2xl px-8">
      You're doing a good job and things are gonna be ok.
    </p>
    <p class="text-sm italic text-white/50 mt-4 text-center">(Except you, Kevin. You know what you did.)</p>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script is:inline>
  const btn = document.getElementById('veryImportantBtn');
  const overlay = document.getElementById('encouragementOverlay');
  const closeBtn = document.getElementById('overlayClose');

  let dismissTimer = null;
  let fadeTimer = null;
  let confettiInterval = null;

  // Ensure confetti canvas sits above the overlay
  function ensureConfettiOnTop() {
    var canvas = document.querySelector('canvas.confetti-canvas') || document.querySelector('canvas[style*="position: fixed"]');
    if (canvas) canvas.style.zIndex = '10000';
  }

  function fireBurst() {
    confetti({
      particleCount: 80,
      spread: 160,
      origin: { y: 0 },
      startVelocity: 45,
      scalar: 1.2
    });
    ensureConfettiOnTop();
  }

  function showOverlay() {
    clearAllTimers();

    overlay.style.transition = 'opacity 300ms';
    overlay.style.display = 'flex';
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        overlay.style.opacity = '1';
      });
    });

    // Continuous confetti every 200ms, stop firing at 4500ms
    fireBurst();
    confettiInterval = setInterval(fireBurst, 200);

    // At 4500ms: stop new bursts and begin fade
    fadeTimer = setTimeout(function () {
      clearInterval(confettiInterval);
      confettiInterval = null;
      overlay.style.transition = 'opacity 500ms';
      overlay.style.opacity = '0';
    }, 4500);

    // At 5000ms: hide and clean up
    dismissTimer = setTimeout(function () {
      hideOverlay();
    }, 5000);
  }

  function clearAllTimers() {
    clearTimeout(dismissTimer);
    clearTimeout(fadeTimer);
    clearInterval(confettiInterval);
    dismissTimer = null;
    fadeTimer = null;
    confettiInterval = null;
  }

  function hideOverlay() {
    clearAllTimers();
    overlay.style.transition = 'opacity 300ms';
    overlay.style.opacity = '0';
    confetti.reset();
    setTimeout(function () {
      overlay.style.display = 'none';
    }, 300);
  }

  btn.addEventListener('click', showOverlay);
  closeBtn.addEventListener('click', hideOverlay);
</script>

<script is:inline>
(function () {
  var CELL = 20, COLS = 21, ROWS = 15;
  var W = COLS * CELL, H = ROWS * CELL; // 420x300
  var BASE_SPEED = 180, MIN_SPEED = 80, SPEED_STEP = 10, APPLES_PER_TIER = 3, MAX_TIERS = 5;

  var canvas = document.getElementById('snake-canvas');
  var ctx = canvas.getContext('2d');
  var scoreEl = document.getElementById('snake-score');
  var bestEl = document.getElementById('snake-best');
  var dotsEl = document.getElementById('snake-speed-dots');

  var snake, dir, nextDir, food, score, loop, started, dead;
  var interval, foodPulseRaf, audioCtx;

  var highScore = parseInt(localStorage.getItem('snake-high-score') || '0', 10);
  bestEl.textContent = 'best: ' + highScore;

  function isDark() {
    return document.documentElement.classList.contains('dark');
  }

  function getAudioCtx() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    return audioCtx;
  }

  function playEat() {
    try {
      var ac = getAudioCtx();
      var osc = ac.createOscillator();
      var gain = ac.createGain();
      osc.connect(gain); gain.connect(ac.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(220, ac.currentTime);
      osc.frequency.linearRampToValueAtTime(440, ac.currentTime + 0.08);
      gain.gain.setValueAtTime(0.15, ac.currentTime);
      gain.gain.linearRampToValueAtTime(0, ac.currentTime + 0.08);
      osc.start(ac.currentTime);
      osc.stop(ac.currentTime + 0.08);
    } catch(e) {}
  }

  function playDeath() {
    try {
      var ac = getAudioCtx();
      var osc = ac.createOscillator();
      var gain = ac.createGain();
      osc.connect(gain); gain.connect(ac.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(440, ac.currentTime);
      osc.frequency.linearRampToValueAtTime(110, ac.currentTime + 0.3);
      gain.gain.setValueAtTime(0.2, ac.currentTime);
      gain.gain.linearRampToValueAtTime(0, ac.currentTime + 0.3);
      osc.start(ac.currentTime);
      osc.stop(ac.currentTime + 0.3);
    } catch(e) {}
  }

  function currentTier() {
    return Math.min(Math.floor(score / APPLES_PER_TIER), MAX_TIERS);
  }

  function currentInterval() {
    return Math.max(BASE_SPEED - currentTier() * SPEED_STEP, MIN_SPEED);
  }

  function updateDots() {
    var tier = currentTier();
    dotsEl.innerHTML = '';
    for (var i = 0; i < MAX_TIERS; i++) {
      var dot = document.createElement('span');
      dot.style.display = 'inline-block';
      dot.style.width = '5px';
      dot.style.height = '5px';
      dot.style.borderRadius = '50%';
      dot.style.background = i < tier ? 'rgba(224,90,58,0.6)' : 'rgba(128,128,128,0.2)';
      dotsEl.appendChild(dot);
    }
  }

  function init() {
    snake = [
      { x: 12, y: 7 },
      { x: 11, y: 7 },
      { x: 10, y: 7 }
    ];
    dir = { x: 1, y: 0 };
    nextDir = { x: 1, y: 0 };
    food = randomFood();
    score = 0;
    dead = false;
    interval = BASE_SPEED;
    scoreEl.textContent = 'score: 0';
    updateDots();
    if (foodPulseRaf) cancelAnimationFrame(foodPulseRaf);
    foodPulseRaf = null;
  }

  function randomFood() {
    var pos;
    do {
      pos = { x: Math.floor(Math.random() * COLS), y: Math.floor(Math.random() * ROWS) };
    } while (snake.some(function (s) { return s.x === pos.x && s.y === pos.y; }));
    return pos;
  }

  function drawBoard(flashRed) {
    var dark = isDark();
    for (var row = 0; row < ROWS; row++) {
      for (var col = 0; col < COLS; col++) {
        var checker = (row + col) % 2 === 0;
        if (flashRed) {
          ctx.fillStyle = checker ? '#5a0a0a' : '#6b1010';
        } else {
          ctx.fillStyle = dark
            ? (checker ? '#0a0a0a' : '#111111')
            : (checker ? '#f9f9f9' : '#f2f2f2');
        }
        ctx.fillRect(col * CELL, row * CELL, CELL, CELL);
      }
    }
  }

  function drawFood(radius) {
    var r = (radius !== undefined) ? radius : CELL / 2 - 2;
    ctx.fillStyle = '#e05a3a';
    ctx.beginPath();
    ctx.arc(food.x * CELL + CELL / 2, food.y * CELL + CELL / 2, r, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawSnake() {
    var dark = isDark();
    for (var i = 0; i < snake.length; i++) {
      var t = i / Math.max(snake.length - 1, 1);
      var alpha = dark ? (1 - t * 0.7) : (1 - t * 0.65);
      ctx.fillStyle = dark
        ? 'rgba(220,220,220,' + alpha + ')'
        : 'rgba(30,30,30,' + alpha + ')';
      ctx.fillRect(snake[i].x * CELL + 1, snake[i].y * CELL + 1, CELL - 2, CELL - 2);
    }
  }

  function draw(foodRadius) {
    drawBoard(false);
    drawFood(foodRadius);
    drawSnake();
  }

  // Food pulse via rAF
  function startFoodPulse() {
    var start = performance.now();
    function pulse(now) {
      if (!started) return;
      var t = ((now - start) % 1000) / 1000; // 0..1 over 1s
      var r = (CELL / 2 - 3) + 2 * (0.5 + 0.5 * Math.sin(t * Math.PI * 2));
      draw(r);
      foodPulseRaf = requestAnimationFrame(pulse);
    }
    foodPulseRaf = requestAnimationFrame(pulse);
  }

  function drawIdle(gameOver) {
    drawBoard(false);
    var dark = isDark();
    ctx.fillStyle = dark ? 'rgba(255,255,255,0.18)' : 'rgba(0,0,0,0.15)';
    ctx.font = '13px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(
      gameOver ? 'game over · press any arrow to restart' : 'press any arrow key to start',
      W / 2, H / 2
    );
  }

  function scheduleLoop() {
    clearInterval(loop);
    loop = setInterval(function () {
      step();
      // Restart interval if speed tier changed
      var newInterval = currentInterval();
      if (newInterval !== interval) {
        interval = newInterval;
        scheduleLoop();
      }
    }, interval);
  }

  function step() {
    dir = nextDir;
    var head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };

    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) return gameOver();
    if (snake.some(function (s) { return s.x === head.x && s.y === head.y; })) return gameOver();

    snake.unshift(head);

    if (head.x === food.x && head.y === food.y) {
      score++;
      scoreEl.textContent = 'score: ' + score;
      updateDots();
      food = randomFood();
      playEat();
    } else {
      snake.pop();
    }
  }

  function flashAndGameOver() {
    clearInterval(loop);
    if (foodPulseRaf) { cancelAnimationFrame(foodPulseRaf); foodPulseRaf = null; }
    playDeath();

    var flashes = 0;
    function doFlash() {
      drawBoard(flashes % 2 === 0);
      drawSnake();
      flashes++;
      if (flashes < 6) {
        setTimeout(doFlash, 50);
      } else {
        finishGameOver();
      }
    }
    doFlash();
  }

  function finishGameOver() {
    dead = true;
    started = false;

    if (score > highScore) {
      highScore = score;
      localStorage.setItem('snake-high-score', highScore);
      bestEl.textContent = 'best: ' + highScore;
    }

    drawIdle(true);
  }

  function gameOver() {
    flashAndGameOver();
  }

  function start() {
    if (started) return;
    init();
    started = true;
    interval = BASE_SPEED;
    scheduleLoop();
    startFoodPulse();
  }

  document.addEventListener('keydown', function (e) {
    var map = {
      ArrowUp:    { x: 0,  y: -1 },
      ArrowDown:  { x: 0,  y:  1 },
      ArrowLeft:  { x: -1, y:  0 },
      ArrowRight: { x: 1,  y:  0 }
    };
    var d = map[e.key];
    if (!d) return;
    e.preventDefault();
    getAudioCtx(); // unlock audio on first keypress
    if (!started) {
      start();
      nextDir = d;
      dir = d;
      return;
    }
    // Prevent reversing
    if (d.x === -dir.x && d.y === -dir.y) return;
    nextDir = d;
  });

  // Initial idle draw
  started = false;
  dead = false;
  snake = [{ x: 12, y: 7 }, { x: 11, y: 7 }, { x: 10, y: 7 }];
  dir = { x: 1, y: 0 };
  nextDir = { x: 1, y: 0 };
  updateDots();
  drawIdle(false);
})();
</script>

</PageLayout>
