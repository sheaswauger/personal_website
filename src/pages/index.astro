---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import { SITE } from "@consts"

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)

const writing = (await getCollection("writing"))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3)
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <!-- HERO -->
  <section class="relative w-full">
    <div class="animate w-full">
      <div class="relative w-full">
        <div class="p-5 pt-32 pb-16 text-center">
          <p class="animated text-5xl md:text-6xl font-bold text-black dark:text-white">
            Shea Swauger
          </p>
          <p class="animated text-xl text-black/60 dark:text-white/60 mt-3 max-w-lg mx-auto">
            Hi there! It's nice to meet you. I'm a researcher and writer who cares about technology, public policy, and education.
          </p>
          <div id="ctaButtons" class="animated flex flex-wrap gap-4 justify-center mt-5">
            <button id="veryImportantBtn" class="bg-transparent border border-white/40 text-white px-5 py-2 rounded-full text-sm hover:bg-white/10 transition-colors cursor-pointer">
              Important Reminder
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>


  <hr class="my-8 border-black/10 dark:border-white/10">

  <!-- Divider -->
  <div class="relative bg-white dark:bg-black">
    <div class="border-t border-black/10 dark:border-white/25"></div>

    <!-- Two-column section -->
    <div class="mx-auto max-w-screen-lg px-5 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Left: Recent Blog Posts -->
        <section class="animate">
          <div class="space-y-4">
            <div class="flex justify-between items-baseline">
              <p class="font-semibold text-black dark:text-white">
                Recent Posts
              </p>
              <a href="/blog" class="group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend text-sm">
                <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                  All posts
                </span>
              </a>
            </div>
            <ul class="space-y-4">
              {posts.map((post) => (
                <li>
                  <ArrowCard entry={post} />
                </li>
              ))}
            </ul>
          </div>
        </section>

        <!-- Right: Recent Writing + Snake -->
        <section class="animate">
          <div class="flex flex-col space-y-4">
            <div class="flex justify-between items-baseline">
              <p class="font-semibold text-black dark:text-white">
                Recent Writing
              </p>
              <a href="/writing" class="group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend text-sm">
                <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                  All writing
                </span>
              </a>
            </div>
            <ul class="space-y-5">
              {writing.map((entry) => (
                <li>
                  <a
                    href={entry.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out"
                  >
                    <div class="font-medium text-black dark:text-white group-hover:underline decoration-[.5px] underline-offset-2 line-clamp-2">
                      {entry.data.title}
                    </div>
                    <div class="text-sm opacity-60 mt-0.5">
                      {entry.data.venue} · {entry.data.year}
                    </div>
                  </a>
                </li>
              ))}
            </ul>

            <!-- Snake game -->
            <div class="flex-1 inline-block">
              <!-- Nokia bezel -->
              <div style="background:#2a2a2a;border-radius:8px;padding:10px 12px 8px;border:2px solid #1a1a1a;display:inline-block;">
                <!-- Score bar inside bezel -->
                <div id="snake-score-bar" style="font-family:monospace;font-size:12px;color:#1a2a0a;background:#8a9e2a;padding:2px 6px 4px;display:flex;justify-content:space-between;margin-bottom:4px;">
                  <span id="snake-score">score: 0</span>
                  <span style="display:flex;align-items:center;gap:6px;">
                    <span id="snake-speed-dots" style="display:flex;gap:3px;"></span>
                    <span id="snake-best">best: 0</span>
                  </span>
                </div>
                <!-- Canvas + demo overlay + scanlines -->
                <div style="position:relative;display:block;">
                  <canvas id="snake-canvas" width="420" height="340" style="display:block;"></canvas>
                  <!-- Demo overlay (removed by JS on first input) -->
                  <div id="snake-demo-overlay" style="position:absolute;inset:0;background:rgba(26,42,10,0.75);display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;">
                    <span style="font-family:monospace;color:#8a9e2a;font-size:22px;font-weight:bold;letter-spacing:4px;">SNAKE</span>
                    <span style="display:block;height:10px;"></span>
                    <span style="font-family:monospace;color:#8a9e2a;font-size:13px;">a game from 1997.</span>
                    <span style="font-family:monospace;color:#8a9e2a;font-size:13px;">you'll figure it out.</span>
                    <span style="display:block;height:10px;"></span>
                    <span style="font-family:monospace;color:#6a7e1a;font-size:12px;">press any arrow to play</span>
                    <span id="snake-swipe-hint" style="font-family:monospace;color:#6a7e1a;font-size:12px;display:none;">or swipe to play</span>
                  </div>
                  <!-- Scanlines -->
                  <div style="position:absolute;inset:0;background:repeating-linear-gradient(to bottom,transparent 0px,transparent 3px,rgba(0,0,0,0.07) 3px,rgba(0,0,0,0.07) 4px);pointer-events:none;"></div>
                </div>
              </div>
              <p class="text-xs text-white/20 text-center mt-2">arrow keys or swipe to play</p>
            </div>
          </div>
        </section>

      </div>
    </div>
  </div>


<!-- Fullscreen encouragement overlay -->
<div id="encouragementOverlay" style="display:none; opacity:0;" class="fixed inset-0 z-[9999] bg-black flex items-center justify-center transition-opacity duration-300">
  <button id="overlayClose" class="absolute top-6 right-8 text-white text-2xl cursor-pointer bg-transparent border-none leading-none">&times;</button>
  <div class="flex flex-col items-center">
    <p class="text-white text-5xl md:text-6xl font-bold text-center max-w-2xl px-8">
      You're doing a good job and things are gonna be ok.
    </p>
    <p class="text-sm italic text-white/50 mt-4 text-center">(Except you, Kevin. You know what you did.)</p>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script is:inline>
  const btn = document.getElementById('veryImportantBtn');
  const overlay = document.getElementById('encouragementOverlay');
  const closeBtn = document.getElementById('overlayClose');

  let dismissTimer = null;
  let fadeTimer = null;
  let confettiInterval = null;

  // Ensure confetti canvas sits above the overlay
  function ensureConfettiOnTop() {
    var canvas = document.querySelector('canvas.confetti-canvas') || document.querySelector('canvas[style*="position: fixed"]');
    if (canvas) canvas.style.zIndex = '10000';
  }

  function fireBurst() {
    confetti({
      particleCount: 80,
      spread: 160,
      origin: { y: 0 },
      startVelocity: 45,
      scalar: 1.2
    });
    ensureConfettiOnTop();
  }

  function showOverlay() {
    clearAllTimers();

    overlay.style.transition = 'opacity 300ms';
    overlay.style.display = 'flex';
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        overlay.style.opacity = '1';
      });
    });

    // Continuous confetti every 200ms, stop firing at 4500ms
    fireBurst();
    confettiInterval = setInterval(fireBurst, 200);

    // At 4500ms: stop new bursts and begin fade
    fadeTimer = setTimeout(function () {
      clearInterval(confettiInterval);
      confettiInterval = null;
      overlay.style.transition = 'opacity 500ms';
      overlay.style.opacity = '0';
    }, 4500);

    // At 5000ms: hide and clean up
    dismissTimer = setTimeout(function () {
      hideOverlay();
    }, 5000);
  }

  function clearAllTimers() {
    clearTimeout(dismissTimer);
    clearTimeout(fadeTimer);
    clearInterval(confettiInterval);
    dismissTimer = null;
    fadeTimer = null;
    confettiInterval = null;
  }

  function hideOverlay() {
    clearAllTimers();
    overlay.style.transition = 'opacity 300ms';
    overlay.style.opacity = '0';
    confetti.reset();
    setTimeout(function () {
      overlay.style.display = 'none';
    }, 300);
  }

  btn.addEventListener('click', showOverlay);
  closeBtn.addEventListener('click', hideOverlay);
</script>

<script is:inline>
(function () {
  var CELL = 20, COLS = 21, ROWS = 17;
  var W = COLS * CELL, H = ROWS * CELL; // 420x340
  var BASE_SPEED = 180, MIN_SPEED = 80, SPEED_STEP = 10, APPLES_PER_TIER = 3, MAX_TIERS = 5;
  var LCD_BG = '#8a9e2a', LCD_FG = '#1a2a0a';

  var canvas = document.getElementById('snake-canvas');
  var ctx = canvas.getContext('2d');
  var scoreEl = document.getElementById('snake-score');
  var bestEl = document.getElementById('snake-best');
  var dotsEl = document.getElementById('snake-speed-dots');
  var overlay = document.getElementById('snake-demo-overlay');
  var swipeHint = document.getElementById('snake-swipe-hint');

  // Show swipe hint on touch devices
  if ('ontouchstart' in window) swipeHint.style.display = '';

  var state = 'demo'; // 'demo' | 'playing' | 'dead'
  var snake, dir, nextDir, food, score, loop, foodPulseRaf, audioCtx;
  var interval;

  var highScore = parseInt(localStorage.getItem('snake-high-score') || '0', 10);
  bestEl.textContent = 'best: ' + highScore;

  // ── Audio ──────────────────────────────────────────────────────────────
  function getAudioCtx() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    return audioCtx;
  }
  function playEat() {
    try {
      var ac = getAudioCtx(), osc = ac.createOscillator(), g = ac.createGain();
      osc.connect(g); g.connect(ac.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(220, ac.currentTime);
      osc.frequency.linearRampToValueAtTime(440, ac.currentTime + 0.08);
      g.gain.setValueAtTime(0.15, ac.currentTime);
      g.gain.linearRampToValueAtTime(0, ac.currentTime + 0.08);
      osc.start(); osc.stop(ac.currentTime + 0.08);
    } catch(e) {}
  }
  function playDeath() {
    try {
      var ac = getAudioCtx(), osc = ac.createOscillator(), g = ac.createGain();
      osc.connect(g); g.connect(ac.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(440, ac.currentTime);
      osc.frequency.linearRampToValueAtTime(110, ac.currentTime + 0.3);
      g.gain.setValueAtTime(0.2, ac.currentTime);
      g.gain.linearRampToValueAtTime(0, ac.currentTime + 0.3);
      osc.start(); osc.stop(ac.currentTime + 0.3);
    } catch(e) {}
  }

  // ── Speed / dots ───────────────────────────────────────────────────────
  function currentTier() { return Math.min(Math.floor(score / APPLES_PER_TIER), MAX_TIERS); }
  function currentInterval() { return Math.max(BASE_SPEED - currentTier() * SPEED_STEP, MIN_SPEED); }
  function updateDots() {
    var tier = currentTier();
    dotsEl.innerHTML = '';
    for (var i = 0; i < MAX_TIERS; i++) {
      var dot = document.createElement('span');
      dot.style.cssText = 'display:inline-block;width:5px;height:5px;border-radius:50%;background:' +
        (i < tier ? LCD_FG : 'rgba(26,42,10,0.2)');
      dotsEl.appendChild(dot);
    }
  }

  // ── Drawing ────────────────────────────────────────────────────────────
  function drawBoard() {
    ctx.fillStyle = LCD_BG;
    ctx.fillRect(0, 0, W, H);
  }
  function drawDiamond(cx, cy, size) {
    ctx.fillStyle = LCD_FG;
    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(Math.PI / 4);
    ctx.fillRect(-size / 2, -size / 2, size, size);
    ctx.restore();
  }
  function drawFood(size) {
    drawDiamond(food.x * CELL + CELL / 2, food.y * CELL + CELL / 2, size || 8);
  }
  function drawSnake() {
    var head = snake[0];
    ctx.fillStyle = LCD_FG;
    for (var i = 0; i < snake.length; i++) {
      ctx.fillRect(snake[i].x * CELL + 1, snake[i].y * CELL + 1, CELL - 2, CELL - 2);
    }
    ctx.fillStyle = LCD_BG;
    var hx = head.x * CELL, hy = head.y * CELL;
    if (dir.x === 1)       { ctx.fillRect(hx+CELL-5, hy+3, 2, 2); ctx.fillRect(hx+CELL-5, hy+CELL-5, 2, 2); }
    else if (dir.x === -1) { ctx.fillRect(hx+3, hy+3, 2, 2);      ctx.fillRect(hx+3, hy+CELL-5, 2, 2); }
    else if (dir.y === -1) { ctx.fillRect(hx+3, hy+3, 2, 2);      ctx.fillRect(hx+CELL-5, hy+3, 2, 2); }
    else                   { ctx.fillRect(hx+3, hy+CELL-5, 2, 2); ctx.fillRect(hx+CELL-5, hy+CELL-5, 2, 2); }
  }
  function drawGameOver() {
    drawBoard();
    drawFood();
    ctx.fillStyle = LCD_FG;
    ctx.font = '12px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('game over · press any arrow to restart', W / 2, H / 2);
  }

  // ── Food pulse (playing state) ─────────────────────────────────────────
  function startFoodPulse() {
    var start = performance.now();
    function pulse(now) {
      if (state !== 'playing') return;
      var t = ((now - start) % 1000) / 1000;
      var size = 7 + 2 * Math.sin(t * Math.PI * 2);
      drawBoard();
      drawDiamond(food.x * CELL + CELL / 2, food.y * CELL + CELL / 2, size);
      drawSnake();
      foodPulseRaf = requestAnimationFrame(pulse);
    }
    foodPulseRaf = requestAnimationFrame(pulse);
  }

  // ── Demo mode ──────────────────────────────────────────────────────────
  // A scripted path: series of {dir, steps} segments that loop the board
  var DEMO_PATH = [
    {x:1,y:0,n:18}, {x:0,y:1,n:4},  {x:-1,y:0,n:18}, {x:0,y:1,n:4},
    {x:1,y:0,n:18}, {x:0,y:1,n:4},  {x:-1,y:0,n:18}, {x:0,y:-1,n:14},
    {x:1,y:0,n:10}, {x:0,y:1,n:6},  {x:-1,y:0,n:10}, {x:0,y:-1,n:6}
  ];
  var DEMO_FOOD = [{x:10,y:3},{x:5,y:7},{x:14,y:9},{x:3,y:4},{x:17,y:12},{x:8,y:14}];
  var demoPathIdx = 0, demoStepInSeg = 0, demoFoodIdx = 0;

  function initDemo() {
    snake = [{x:10,y:8},{x:9,y:8},{x:8,y:8}];
    dir = {x:1,y:0}; nextDir = {x:1,y:0};
    demoPathIdx = 0; demoStepInSeg = 0; demoFoodIdx = 0;
    food = DEMO_FOOD[0];
    drawBoard(); drawFood(); drawSnake();
  }

  function demoStep() {
    var seg = DEMO_PATH[demoPathIdx];
    dir = {x: seg.x, y: seg.y};
    var head = {x: snake[0].x + dir.x, y: snake[0].y + dir.y};

    // If about to hit wall or self, silently reset
    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS ||
        snake.some(function(s){ return s.x===head.x && s.y===head.y; })) {
      initDemo(); return;
    }

    snake.unshift(head);
    if (head.x === food.x && head.y === food.y) {
      demoFoodIdx = (demoFoodIdx + 1) % DEMO_FOOD.length;
      food = DEMO_FOOD[demoFoodIdx];
    } else {
      snake.pop();
    }

    demoStepInSeg++;
    if (demoStepInSeg >= seg.n) {
      demoStepInSeg = 0;
      demoPathIdx = (demoPathIdx + 1) % DEMO_PATH.length;
    }

    drawBoard(); drawFood(); drawSnake();
  }

  function startDemo() {
    state = 'demo';
    initDemo();
    loop = setInterval(demoStep, 200);
  }

  // ── Real game ──────────────────────────────────────────────────────────
  function randomFood() {
    var pos;
    do { pos = {x: Math.floor(Math.random()*COLS), y: Math.floor(Math.random()*ROWS)}; }
    while (snake.some(function(s){ return s.x===pos.x && s.y===pos.y; }));
    return pos;
  }

  function initGame() {
    snake = [{x:12,y:8},{x:11,y:8},{x:10,y:8}];
    dir = {x:1,y:0}; nextDir = {x:1,y:0};
    food = randomFood();
    score = 0; interval = BASE_SPEED;
    scoreEl.textContent = 'score: 0';
    updateDots();
    if (foodPulseRaf) { cancelAnimationFrame(foodPulseRaf); foodPulseRaf = null; }
  }

  function scheduleLoop() {
    clearInterval(loop);
    loop = setInterval(function () {
      gameStep();
      var ni = currentInterval();
      if (ni !== interval) { interval = ni; scheduleLoop(); }
    }, interval);
  }

  function gameStep() {
    dir = nextDir;
    var head = {x: snake[0].x + dir.x, y: snake[0].y + dir.y};
    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) return doGameOver();
    if (snake.some(function(s){ return s.x===head.x && s.y===head.y; })) return doGameOver();
    snake.unshift(head);
    if (head.x === food.x && head.y === food.y) {
      score++;
      scoreEl.textContent = 'score: ' + score;
      updateDots();
      food = randomFood();
      playEat();
    } else { snake.pop(); }
  }

  function doGameOver() {
    clearInterval(loop);
    if (foodPulseRaf) { cancelAnimationFrame(foodPulseRaf); foodPulseRaf = null; }
    playDeath();
    state = 'dead';
    if (score > highScore) {
      highScore = score;
      localStorage.setItem('snake-high-score', highScore);
      bestEl.textContent = 'best: ' + highScore;
    }
    drawGameOver();
  }

  // ── Dismiss overlay + start real game ─────────────────────────────────
  function beginPlaying(d) {
    if (state === 'playing') return;
    clearInterval(loop);

    if (overlay) {
      overlay.style.transition = 'opacity 200ms';
      overlay.style.opacity = '0';
      setTimeout(function(){ if (overlay.parentNode) overlay.parentNode.removeChild(overlay); }, 220);
    }

    state = 'playing';
    initGame();
    dir = d; nextDir = d;
    scheduleLoop();
    startFoodPulse();
  }

  // ── Input handling ─────────────────────────────────────────────────────
  var DIR_MAP = {
    ArrowUp:{x:0,y:-1}, ArrowDown:{x:0,y:1},
    ArrowLeft:{x:-1,y:0}, ArrowRight:{x:1,y:0}
  };

  document.addEventListener('keydown', function (e) {
    var d = DIR_MAP[e.key];
    if (!d) return;
    e.preventDefault();
    getAudioCtx();
    if (state === 'demo') { beginPlaying(d); return; }
    if (state === 'dead') {
      state = 'playing';
      initGame();
      dir = d; nextDir = d;
      scheduleLoop();
      startFoodPulse();
      return;
    }
    if (d.x === -dir.x && d.y === -dir.y) return;
    nextDir = d;
  });

  var touchStartX = 0, touchStartY = 0;
  canvas.addEventListener('touchstart', function (e) {
    e.preventDefault();
    touchStartX = e.changedTouches[0].clientX;
    touchStartY = e.changedTouches[0].clientY;
  }, { passive: false });

  canvas.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - touchStartX;
    var dy = e.changedTouches[0].clientY - touchStartY;
    var d = null;
    if (Math.abs(dx) > Math.abs(dy)) {
      if (dx > 30)  d = {x:1,y:0};
      if (dx < -30) d = {x:-1,y:0};
    } else {
      if (dy > 30)  d = {x:0,y:1};
      if (dy < -30) d = {x:0,y:-1};
    }
    if (!d) return;
    getAudioCtx();
    if (state === 'demo') { beginPlaying(d); return; }
    if (state === 'dead') {
      state = 'playing';
      initGame();
      dir = d; nextDir = d;
      scheduleLoop();
      startFoodPulse();
      return;
    }
    if (d.x === -dir.x && d.y === -dir.y) return;
    nextDir = d;
  });

  // ── Boot ───────────────────────────────────────────────────────────────
  updateDots();
  startDemo();
})();
</script>

</PageLayout>
