---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import HalftoneText from "@components/HalftoneText.astro"
import HalftoneHDivider from "@components/HalftoneHDivider.astro"
import { SITE } from "@consts"

const writing = (await getCollection("writing"))
  .sort((a, b) => b.data.year - a.data.year)

const presentations = (await getCollection("presentations"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const grants = (await getCollection("grants"))
  .sort((a, b) => b.data.year - a.data.year)

const press = (await getCollection("press"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <!-- HERO -->
  <section class="relative w-full overflow-hidden">
    <div class="animate max-w-screen-lg mx-auto px-5 pt-36 pb-20">
      <h1 class="display-title">Shea Swauger</h1>
      <p class="text-base text-white/55 mt-5 max-w-xl leading-relaxed">
        A researcher and writer who cares about privacy, data, ethics, and education. Currently a PhD student examining surveillance, algorithmic systems, and academic institutions.
      </p>
      <div class="flex flex-wrap gap-4 mt-8">
        <a href="/writing" class="inline-block border border-[#d4a8bc] text-[#d4a8bc] px-6 py-3 text-sm uppercase tracking-widest hover:bg-[#d4a8bc] hover:text-[#0d0d0d] transition-colors duration-200">
          Read my writing
        </a>
        <a href="/presentations" class="inline-block border border-white/30 text-white/60 px-6 py-3 text-sm uppercase tracking-widest hover:border-[#d4a8bc] hover:text-[#d4a8bc] transition-colors duration-200">
          View presentations
        </a>
      </div>
    </div>
    <HalftoneText />
  </section>

  <!-- Sections -->
  <div class="max-w-screen-lg mx-auto px-5 pb-24">

    <HalftoneHDivider />

    <!-- Writing -->
    <section class="animate py-10">
      <div class="flex justify-between items-baseline mb-5">
        <span class="text-[10px] uppercase tracking-widest text-white/30">Writing &middot; {writing.length}</span>
        <a href="/writing" class="text-[10px] uppercase tracking-widest text-[#d4a8bc] hover:underline transition-colors duration-200">See all ↗</a>
      </div>
      <ul class="border-t border-white/[0.07]">
        {writing.slice(0, 3).map((entry, i) => (
          <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
            <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <a
                href={entry.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-white hover:text-[#d4a8bc] transition-colors duration-200 line-clamp-2"
              >
                {entry.data.title}
              </a>
              <div class="text-xs text-white/40 mt-0.5">{entry.data.venue}</div>
            </div>
            <span class="text-xs text-white/35 text-right tabular-nums mt-0.5">{entry.data.year}</span>
          </li>
        ))}
      </ul>
    </section>

    <HalftoneHDivider />

    <!-- Presentations -->
    <section class="animate py-10">
      <div class="flex justify-between items-baseline mb-5">
        <span class="text-[10px] uppercase tracking-widest text-white/30">Presentations &middot; {presentations.length}</span>
        <a href="/presentations" class="text-[10px] uppercase tracking-widest text-[#d4a8bc] hover:underline transition-colors duration-200">See all ↗</a>
      </div>
      <ul class="border-t border-white/[0.07]">
        {presentations.slice(0, 3).map((entry, i) => (
          <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
            <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <div class="text-sm text-white line-clamp-2">{entry.data.title}</div>
              <div class="text-xs text-white/40 mt-0.5">{entry.data.event}</div>
            </div>
            <span class="text-xs text-white/35 text-right tabular-nums mt-0.5">{entry.data.date.getFullYear()}</span>
          </li>
        ))}
      </ul>
    </section>

    <HalftoneHDivider />

    <!-- Grants -->
    <section class="animate py-10">
      <div class="flex justify-between items-baseline mb-5">
        <span class="text-[10px] uppercase tracking-widest text-white/30">Grants &middot; {grants.length}</span>
        <a href="/grants" class="text-[10px] uppercase tracking-widest text-[#d4a8bc] hover:underline transition-colors duration-200">See all ↗</a>
      </div>
      <ul class="border-t border-white/[0.07]">
        {grants.slice(0, 3).map((entry, i) => (
          <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
            <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <div class="text-sm text-white line-clamp-2">{entry.data.title}</div>
              <div class="text-xs text-white/40 mt-0.5">{entry.data.funder}</div>
            </div>
            <span class="text-xs text-white/35 text-right tabular-nums mt-0.5">{entry.data.year}</span>
          </li>
        ))}
      </ul>
    </section>

    <HalftoneHDivider />

    <!-- Press -->
    <section class="animate py-10">
      <div class="flex justify-between items-baseline mb-5">
        <span class="text-[10px] uppercase tracking-widest text-white/30">Press &middot; {press.length}</span>
        <a href="/press" class="text-[10px] uppercase tracking-widest text-[#d4a8bc] hover:underline transition-colors duration-200">See all ↗</a>
      </div>
      <ul class="border-t border-white/[0.07]">
        {press.slice(0, 3).map((entry, i) => (
          <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
            <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">{String(i + 1).padStart(2, '0')}</span>
            <div>
              {entry.data.url ? (
                <a
                  href={entry.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-white hover:text-[#d4a8bc] transition-colors duration-200 line-clamp-2"
                >
                  {entry.data.title}
                </a>
              ) : (
                <div class="text-sm text-white line-clamp-2">{entry.data.title}</div>
              )}
              <div class="text-xs text-white/40 mt-0.5">{entry.data.outlet}</div>
            </div>
            <span class="text-xs text-[#d4a8bc]/50 text-right mt-0.5">
              {entry.data.url ? "↗" : ""}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <HalftoneHDivider />

    <!-- Blog -->
    <section class="animate py-10">
      <div class="flex justify-between items-baseline mb-5">
        <span class="text-[10px] uppercase tracking-widest text-white/30">Blog &middot; {posts.length}</span>
        <a href="/blog" class="text-[10px] uppercase tracking-widest text-[#d4a8bc] hover:underline transition-colors duration-200">See all ↗</a>
      </div>
      <ul class="border-t border-white/[0.07]">
        {posts.slice(0, 3).map((entry, i) => (
          <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
            <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <a
                href={`/blog/${entry.slug}`}
                class="text-sm text-white hover:text-[#d4a8bc] transition-colors duration-200 line-clamp-2"
              >
                {entry.data.title}
              </a>
              <div class="text-xs text-white/40 mt-0.5">
                {entry.data.date.toLocaleDateString("en-US", { month: "short", year: "numeric" })}
              </div>
            </div>
            <span class="text-xs text-white/35 text-right tabular-nums mt-0.5">
              {entry.data.date.getFullYear()}
            </span>
          </li>
        ))}
      </ul>
    </section>

  </div>

</PageLayout>
