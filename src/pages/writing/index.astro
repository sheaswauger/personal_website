---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { WRITING } from "@consts"

const allWriting = await getCollection("writing")
const writing = allWriting.sort((a, b) => b.data.year - a.data.year)

const academic = writing.filter(w => w.data.category !== "journalism")
const journalism = writing.filter(w => w.data.category === "journalism")
---

<PageLayout title={WRITING.TITLE} description={WRITING.DESCRIPTION}>
  <TopLayout>
    <div class="animate">
      <p class="text-[10px] uppercase tracking-widest text-white/30">{WRITING.TITLE}</p>
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">

      <!-- Academic -->
      <p class="text-[9px] uppercase tracking-widest text-white/20 mb-4">Academic</p>
      <ul class="border-t border-white/[0.07]">
        {academic.map((entry, i) => (
          <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
            <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">{String(i + 1).padStart(2, '0')}</span>
            <div class="min-w-0">
              <a
                href={entry.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-white hover:text-[#d4a8bc] transition-colors duration-200 line-clamp-2"
              >
                {entry.data.title}
              </a>
              <div class="text-xs text-white/40 mt-0.5">
                {entry.data.venue}
                {entry.data.authors && entry.data.authors.length > 0 && (
                  <span class="text-white/25"> &middot; {entry.data.authors.join(", ")}</span>
                )}
              </div>
            </div>
            <span class="text-xs text-white/35 text-right tabular-nums mt-0.5">{entry.data.year}</span>
          </li>
        ))}
      </ul>

      <!-- Divider -->
      <div class="my-10 border-t border-white/[0.07]"></div>

      <!-- Journalism -->
      <p class="text-[9px] uppercase tracking-widest text-white/20 mb-4">Journalism</p>
      <ul class="border-t border-white/[0.07]">
        {journalism.map((entry, i) => (
          <li class="py-4 border-b border-white/[0.07] grid grid-cols-[2rem_1fr_3rem] gap-4 items-start">
            <span class="font-mono text-xs text-[#d4a8bc]/30 mt-0.5 select-none">{String(i + 1).padStart(2, '0')}</span>
            <div class="min-w-0">
              <a
                href={entry.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-white hover:text-[#d4a8bc] transition-colors duration-200 line-clamp-2"
              >
                {entry.data.title}
              </a>
              <div class="text-xs text-white/40 mt-0.5">
                {entry.data.venue}
                {entry.data.authors && entry.data.authors.length > 0 && (
                  <span class="text-white/25"> &middot; {entry.data.authors.join(", ")}</span>
                )}
              </div>
            </div>
            <span class="text-xs text-white/35 text-right tabular-nums mt-0.5">{entry.data.year}</span>
          </li>
        ))}
      </ul>

    </div>
  </BottomLayout>
</PageLayout>
